flowchart TD
    A[Nhận HTTP request] --> B{Endpoint?}

    B -->|POST /users| C1{Email đã tồn tại<br/>trong users?}
    C1 -->|Có| C2[Return 409 Conflict]
    C1 -->|Không| C3[Insert User record]
    C3 --> C4[Return 201 + user]

    B -->|"GET /users/{id}"| G1[Query User by PK]
    G1 --> G2{Tồn tại?}
    G2 -->|Không| G3[Return 404 Not Found]
    G2 -->|Có| G4[Return 200 + user]

    B -->|GET /users| L1[Query all users<br/>ORDER BY id]
    L1 --> L2[Return 200 + list]

    classDef start fill:#e8f5e9,stroke:#43a047,color:#1b5e20;
    classDef decision fill:#fff3e0,stroke:#fb8c00,color:#e65100;
    classDef action fill:#e3f2fd,stroke:#1e88e5,color:#0d47a1;
    classDef error fill:#ffebee,stroke:#e53935,color:#b71c1c;
    class A start;
    class B,C1,G2 decision;
    class C3,C4,G1,G4,L1,L2 action;
    class C2,G3 error;
