flowchart TD
    A[Nhận HTTP request] --> B{Endpoint?}

    B -->|GET /movies| L1[Query all movies]
    L1 --> L2[Return 200 + list]

    B -->|"GET /movies/{id}"| M1[Query movie + showtimes eager-load]
    M1 --> M2{Tồn tại?}
    M2 -->|Không| M3[Return 404]
    M2 -->|Có| M4[Return 200 + movie]

    B -->|"GET /showtimes/{id}/seats"| S1[Query seats theo showtime_id]
    S1 --> S2[Return 200 + list seats]

    B -->|POST /seats/reserve| R1[Bắt đầu DB transaction]
    R1 --> R2[SELECT ... FOR UPDATE<br/>lock seat rows]
    R2 --> R3{Tất cả ghế<br/>status = AVAILABLE?}
    R3 -->|Không| R4[Rollback → 409 Conflict]
    R3 -->|Có| R5[UPDATE status = PENDING<br/>set booking_id]
    R5 --> R6[Commit → Return 200]

    B -->|POST /seats/confirm| CF1[UPDATE PENDING → BOOKED<br/>WHERE booking_id = ?]
    CF1 --> CF2[Return 200]

    B -->|POST /seats/release| RL1[UPDATE PENDING → AVAILABLE<br/>clear booking_id]
    RL1 --> RL2[Return 200]

    classDef start fill:#e8f5e9,stroke:#43a047,color:#1b5e20;
    classDef decision fill:#fff3e0,stroke:#fb8c00,color:#e65100;
    classDef action fill:#e3f2fd,stroke:#1e88e5,color:#0d47a1;
    classDef error fill:#ffebee,stroke:#e53935,color:#b71c1c;
    class A start;
    class B,M2,R3 decision;
    class L1,L2,M1,M4,S1,S2,R1,R2,R5,R6,CF1,CF2,RL1,RL2 action;
    class M3,R4 error;
