sequenceDiagram
    actor C as Customer
    participant FE as Frontend
    participant GW as Gateway
    participant B as BookingService
    participant M as MovieService
    participant V as VoucherService
    participant P as PaymentService
    participant N as NotificationService
    participant T as Temporal Worker

    C->>FE: Chọn phim, suất, ghế, voucher
    FE->>GW: POST /bookings
    GW->>B: POST /bookings (JWT verified)

    B->>M: GET /showtimes/{id}
    M-->>B: showtime + base_price
    B->>M: POST /seats/reserve
    M-->>B: seats PENDING (booking_id)
    B->>V: POST /vouchers/validate (nếu có)
    V-->>B: discount_amount
    B->>P: POST /payments/create
    P-->>B: payment_id + payment_url
    B->>B: persist booking AWAITING_PAYMENT
    B->>T: start BookingWorkflow(booking_id, payment_id, ...)
    B-->>GW: 201 {booking_id, workflow_id, payment_url}
    GW-->>FE: 201
    FE->>C: Redirect tới payment_url
    C->>P: Thanh toán (VNPay / mock confirm)
    P->>P: Cập nhật status SUCCESS / FAILED

    loop Poll mỗi 5s, tối đa 5 phút
        T->>P: GET /payments/{id}
        P-->>T: status
    end

    alt Payment SUCCESS
        T->>M: POST /seats/confirm
        M-->>T: BOOKED
        T->>V: POST /vouchers/redeem (nếu có)
        V-->>T: used_count++
        T->>N: POST /notifications/send
        N-->>T: 202 Accepted
        T->>B: finalize booking → ACTIVE
    else Payment FAILED / timeout
        T->>M: POST /seats/release
        M-->>T: AVAILABLE
        T->>B: finalize booking → CANCELLED (reason)
    end
