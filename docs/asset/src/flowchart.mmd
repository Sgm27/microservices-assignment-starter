flowchart TD
    Start([Khách hàng truy cập]) --> Browse[1. Duyệt phim]
    Browse --> GetDetail[2. Lấy chi tiết phim + suất chiếu]
    GetDetail --> PickShowtime[3. Chọn suất chiếu]
    PickShowtime --> ListSeats[4. Lấy danh sách ghế]
    ListSeats --> PickSeats[5. Chọn ghế AVAILABLE]
    PickSeats --> AuthCheck{6. JWT hợp lệ?}
    AuthCheck -->|Không| Login[Yêu cầu đăng nhập]
    Login --> AuthCheck
    AuthCheck -->|Có| VoucherOpt{7. Có voucher?}
    VoucherOpt -->|Có| ValidateVoucher[8. Validate voucher<br/>tính discount_amount]
    VoucherOpt -->|Không| Reserve
    ValidateVoucher --> Reserve[9. Reserve ghế<br/>AVAILABLE → PENDING]
    Reserve --> CreatePayment[10. Tạo payment PENDING<br/>sinh payment_url]
    CreatePayment --> PersistBooking[11. Persist booking<br/>AWAITING_PAYMENT]
    PersistBooking --> Redirect[12. Redirect sang payment_url]
    Redirect --> Pay[13. Khách thanh toán]
    Pay --> Callback[14. Payment service nhận<br/>IPN / mock confirm]
    Callback --> Poll{15. Temporal workflow poll<br/>payment status < 5 phút}
    Poll -->|SUCCESS| Confirm[16. Confirm ghế<br/>PENDING → BOOKED]
    Confirm --> Redeem[17. Redeem voucher<br/>used_count++]
    Redeem --> Notify[18. Gửi email xác nhận]
    Notify --> Active[19. Booking → ACTIVE]
    Active --> End([21. Kết thúc])
    Poll -->|FAILED / timeout| Release[20a. Release ghế<br/>PENDING → AVAILABLE]
    Release --> Cancel[20b. Booking → CANCELLED]
    Cancel --> End

    classDef sys fill:#e3f2fd,stroke:#1e88e5,color:#0d47a1;
    classDef human fill:#fff3e0,stroke:#fb8c00,color:#e65100;
    classDef terminal fill:#e8f5e9,stroke:#43a047,color:#1b5e20;
    class Browse,PickShowtime,PickSeats,Pay human;
    class GetDetail,ListSeats,AuthCheck,ValidateVoucher,Reserve,CreatePayment,PersistBooking,Redirect,Callback,Poll,Confirm,Redeem,Notify,Active,Release,Cancel,Login,VoucherOpt sys;
    class Start,End terminal;
