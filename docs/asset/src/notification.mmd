flowchart TD
    A[Nhận HTTP request] --> B{Endpoint?}

    B -->|POST /notifications/send| S1[Validate to / subject / body]
    S1 --> S2[Insert notification<br/>status=PENDING]
    S2 --> S3{SMTP enabled<br/>trong config?}
    S3 -->|Không| S4[Skip send log-only<br/>status=SKIPPED]
    S3 -->|Có| S5[Gửi email qua SMTP]
    S5 --> S6{Send OK?}
    S6 -->|Có| S7[UPDATE status=SENT]
    S6 -->|Không| S8[UPDATE status=FAILED<br/>+ error message]
    S4 --> S9[Return 202 Accepted]
    S7 --> S9
    S8 --> S9

    B -->|GET /notifications| L1[Query all<br/>ORDER BY created_at DESC]
    L1 --> L2[Return 200 + list]

    B -->|"GET /notifications/{id}"| G1[Query by id]
    G1 --> G2{Tồn tại?}
    G2 -->|Không| G3[Return 404]
    G2 -->|Có| G4[Return 200 + notification]

    classDef start fill:#e8f5e9,stroke:#43a047,color:#1b5e20;
    classDef decision fill:#fff3e0,stroke:#fb8c00,color:#e65100;
    classDef action fill:#e3f2fd,stroke:#1e88e5,color:#0d47a1;
    classDef error fill:#ffebee,stroke:#e53935,color:#b71c1c;
    class A start;
    class B,S3,S6,G2 decision;
    class S1,S2,S4,S5,S7,S8,S9,L1,L2,G1,G4 action;
    class G3 error;
