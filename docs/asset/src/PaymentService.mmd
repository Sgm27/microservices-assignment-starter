flowchart TD
    A[Nhận HTTP request] --> B{Endpoint?}

    B -->|POST /payments/create| P1[Validate booking_id + amount]
    P1 --> P2{Provider?}
    P2 -->|VNPay| P3[Insert payment PENDING<br/>sinh VNPay payment_url + checksum]
    P2 -->|Mock| P4["Insert payment PENDING<br/>payment_url = /payments/mock/{id}/page"]
    P3 --> P5[Return 200 + payment_url]
    P4 --> P5

    B -->|"GET /payments/{id}"| G1[Query payment by id]
    G1 --> G2{Tồn tại?}
    G2 -->|Không| G3[Return 404]
    G2 -->|Có| G4[Return 200 + status]

    B -->|"GET /payments/by-booking/{id}"| BG1[Query WHERE booking_id]
    BG1 --> BG2{Tồn tại?}
    BG2 -->|Không| BG3[Return 404]
    BG2 -->|Có| BG4[Return 200 + payment]

    B -->|"GET /payments/mock/{id}/page"| MP1[Render HTML form<br/>SUCCESS / FAILED]

    B -->|"POST /payments/mock/{id}/confirm"| MC1[Validate body action]
    MC1 --> MC2[UPDATE status<br/>= SUCCESS hoặc FAILED]
    MC2 --> MC3[Return 200]

    B -->|GET /payments/vnpay-return| VR1[Xác minh VNPay checksum]
    VR1 --> VR2{Valid?}
    VR2 -->|Không| VR3[Return 400]
    VR2 -->|Có| VR4[Cập nhật status<br/>SUCCESS hoặc FAILED]
    VR4 --> VR5[Return 200 + redirect]

    classDef start fill:#e8f5e9,stroke:#43a047,color:#1b5e20;
    classDef decision fill:#fff3e0,stroke:#fb8c00,color:#e65100;
    classDef action fill:#e3f2fd,stroke:#1e88e5,color:#0d47a1;
    classDef error fill:#ffebee,stroke:#e53935,color:#b71c1c;
    class A start;
    class B,P2,G2,BG2,VR2 decision;
    class P1,P3,P4,P5,G1,G4,BG1,BG4,MP1,MC1,MC2,MC3,VR1,VR4,VR5 action;
    class G3,BG3,VR3 error;
