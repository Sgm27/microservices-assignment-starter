# ==============================================
# Cinema Ticket Booking — Environment Variables
# Copy to .env and fill in the values
# ==============================================

COMPOSE_PROJECT_NAME=cinema-booking
ENVIRONMENT=development

# --- MySQL ---
DB_HOST=mysql-db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=rootpass

# --- Database Names (one per service) ---
AUTH_DB_NAME=auth_db
USER_DB_NAME=user_db
MOVIE_DB_NAME=movie_db
VOUCHER_DB_NAME=voucher_db
BOOKING_DB_NAME=booking_db
PAYMENT_DB_NAME=payment_db
NOTIFICATION_DB_NAME=notification_db

# --- Service Ports ---
GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5001
USER_SERVICE_PORT=5002
MOVIE_SERVICE_PORT=5003
VOUCHER_SERVICE_PORT=5004
BOOKING_SERVICE_PORT=5005
PAYMENT_SERVICE_PORT=5006
NOTIFICATION_SERVICE_PORT=5007
FRONTEND_PORT=5173

# --- Security ---
JWT_SECRET=super-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Internal Service URLs (Docker DNS) ---
AUTH_SERVICE_URL=http://auth-service:5001
USER_SERVICE_URL=http://user-service:5002
MOVIE_SERVICE_URL=http://movie-service:5003
VOUCHER_SERVICE_URL=http://voucher-service:5004
BOOKING_SERVICE_URL=http://booking-service:5005
PAYMENT_SERVICE_URL=http://payment-service:5006
NOTIFICATION_SERVICE_URL=http://notification-service:5007

# --- Temporal ---
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=booking-task-queue

# --- Email (notification) ---
EMAIL_MOCK=true
EMAIL_USER=
EMAIL_PASS=

# --- VNPay (payment) ---
PAYMENT_MOCK=true
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5006/payments/vnpay-return
VNPAY_FRONTEND_RETURN_URL=http://localhost:5173/booking/payment-result

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:5000
